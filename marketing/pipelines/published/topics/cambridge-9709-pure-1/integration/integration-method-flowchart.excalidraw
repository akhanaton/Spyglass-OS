      "type": "text",
      "x": 340,
      "y": 555,
      "width": 260,
      "height": 30,
      "text": "e.g. ∫ (3x² + 4x - 5) dx → x³ + 2x² - 5x + C",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "center",
      "angle": 0,
      "strokeColor": "#8B92A0",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
