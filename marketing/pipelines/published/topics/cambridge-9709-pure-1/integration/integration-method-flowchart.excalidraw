    {
      "id": "example-1",
      "type": "text",
      "x": 30,
      "y": 480,
      "width": 240,
      "height": 44,
      "text": "e.g. ∫ 3/√x dx\n→ rewrite as 3x^(-1/2) → power rule",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "center",
      "angle": 0,
      "strokeColor": "#8B92A0",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100
    },
    {
      "id": "example-2",
      "type": "text",
      "x": 720,
      "y": 400,
      "width": 260,
      "height": 30,
      "text": "e.g. ∫ (2x+3)^4 dx → (2x+3)^5 / 10 + C",
      "fontSize": 11,
      "fontFamily": 1,
      "textAlign": "center",
      "angle": 0,
      "strokeColor": "#8B92A0",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100
    },
