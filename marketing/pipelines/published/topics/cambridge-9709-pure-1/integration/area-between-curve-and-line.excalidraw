      "fontFamily": 1,
      "textAlign": "center",
      "angle": 0,
      "strokeColor": "#148A87",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100
    },

    {
      "id": "brace-top",
      "type": "text",
      "x": 80,
      "y": 200,
      "width": 60,
      "height": 20,
      "text": "f(x) →",
