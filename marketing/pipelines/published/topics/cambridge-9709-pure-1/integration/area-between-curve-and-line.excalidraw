    },

    {
      "id": "step-box",
      "type": "rectangle",
      "x": 80,
      "y": 420,
      "width": 520,
      "height": 110,
      "angle": 0,
      "strokeColor": "#19A5A1",
      "backgroundColor": "#F0FDFC",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100,
      "roundness": { "type": 3 }
    },
    {
      "id": "step-text",
      "type": "text",
      "x": 100,
      "y": 430,
      "width": 480,
      "height": 90,
      "text": "Method:\n1. SKETCH the curve and line (even a rough sketch helps)\n2. FIND intersection points: solve f(x) = g(x) → these are your limits\n3. IDENTIFY which function is on top between the limits\n4. SUBTRACT lower from upper: ∫ₚq [f(x) − g(x)] dx\n5. INTEGRATE and evaluate — the answer is always positive",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "angle": 0,
      "strokeColor": "#3E4C59",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100
    },

    {
      "id": "tip-text",
      "type": "text",
      "x": 100,
      "y": 545,
      "width": 480,
      "height": 20,
      "text": "Exam tip: If your answer is negative, you probably subtracted in the wrong order.",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "center",
      "angle": 0,
      "strokeColor": "#FF7A00",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "opacity": 100
    }
  ],
