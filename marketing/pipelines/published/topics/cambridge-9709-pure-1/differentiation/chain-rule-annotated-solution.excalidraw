    },
    {
      "id": "step1-text",
      "type": "text",
      "x": 100,
      "y": 120,
      "width": 500,
      "height": 20,
      "text": "Identify the OUTER function and INNER function",
      "fontSize": 14,
      "fontFamily": 1
    },
    {
      "id": "outer-box",
      "type": "rectangle",
      "x": 120,
      "y": 150,
