      "id": "step2-math-text",
      "type": "text",
      "x": 140,
      "y": 270,
      "width": 430,
      "height": 20,
      "text": "5 × (3x + 2)⁴       ← power comes down, power reduces by 1",
      "fontSize": 14,
      "fontFamily": 1,
      "strokeColor": "#2f9e44"
    },
    {
      "id": "step3-label",
      "type": "text",
      "x": 30,
      "y": 330,
      "width": 60,
      "height": 20,
      "text": "Step 3:",
      "fontSize": 14,
      "fontFamily": 1,
      "strokeColor": "#e8590c"
    },
    {
      "id": "step3-text",
      "type": "text",
      "x": 100,
      "y": 330,
      "width": 500,
      "height": 20,
      "text": "MULTIPLY by the derivative of the INNER",
      "fontSize": 14,
      "fontFamily": 1
    },
    {
      "id": "step3-math",
      "type": "rectangle",
      "x": 120,
      "y": 360,
      "width": 470,
      "height": 40,
      "strokeColor": "#e8590c",
      "backgroundColor": "#fff4e6",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roundness": { "type": 3 }
    },
    {
      "id": "step3-math-text",
      "type": "text",
      "x": 140,
      "y": 370,
      "width": 430,
      "height": 20,
      "text": "× 3       ← derivative of (3x + 2) is 3. THIS IS THE STEP STUDENTS FORGET.",
      "fontSize": 14,
      "fontFamily": 1,
      "strokeColor": "#e8590c"
    },
    {
      "id": "result-box",
      "type": "rectangle",
      "x": 120,
      "y": 430,
      "width": 470,
      "height": 50,
      "strokeColor": "#5c7cfa",
      "backgroundColor": "#dbe4ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
