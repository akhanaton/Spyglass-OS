    {
      "id": "result-text",
      "type": "text",
      "x": 180,
      "y": 442,
      "width": 350,
      "height": 25,
      "text": "dy/dx = 5 × 3 × (3x + 2)⁴ = 15(3x + 2)⁴",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "center"
    }
  ],
