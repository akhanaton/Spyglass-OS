      "height": 20,
      "text": "Step 2:",
      "fontSize": 14,
      "fontFamily": 1,
      "strokeColor": "#e8590c"
    },
    {
      "id": "step2-text",
      "type": "text",
      "x": 100,
      "y": 230,
      "width": 500,
      "height": 20,
      "text": "Differentiate the OUTER (power rule: bring power down, subtract 1)",
      "fontSize": 14,
      "fontFamily": 1
    },
    {
      "id": "step2-math",
      "type": "rectangle",
      "x": 120,
      "y": 260,
      "width": 470,
      "height": 40,
      "strokeColor": "#2f9e44",
      "backgroundColor": "#d3f9d8",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roundness": { "type": 3 }
    },
