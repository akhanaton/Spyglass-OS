{
  "type": "excalidraw",
  "version": 2,
  "source": "seomachine-pre-write",
  "elements": [
    {
      "id": "title",
      "type": "text",
      "x": 200,
      "y": 10,
      "width": 400,
      "height": 30,
      "text": "Which Method Do I Use?",
      "fontSize": 28,
      "fontFamily": 1,
      "textAlign": "center",
      "strokeColor": "#1e1e1e"
    },
    {
      "id": "start-box",
      "type": "rectangle",
      "x": 250,
      "y": 60,
      "width": 300,
      "height": 50,
      "strokeColor": "#339af0",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roughness": 0,
      "roundness": { "type": 3, "value": 10 }
    },
    {
      "id": "start-text",
      "type": "text",
      "x": 290,
      "y": 70,
      "width": 220,
      "height": 30,
      "text": "Look at the equation",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "center",
      "strokeColor": "#1e1e1e"
    },
    {
      "id": "arrow-down",
      "type": "arrow",
      "x": 400,
      "y": 110,
      "width": 0,
      "height": 30,
      "points": [[0, 0], [0, 30]],
      "strokeColor": "#868e96",
      "strokeWidth": 2,
      "roughness": 0
    },
    {
      "id": "diamond",
      "type": "diamond",
      "x": 280,
      "y": 150,
      "width": 240,
      "height": 100,
      "strokeColor": "#e8590c",
      "backgroundColor": "#ffd8a8",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "roughness": 0
    },
    {
      "id": "diamond-text",
      "type": "text",
      "x": 320,
      "y": 180,
      "width": 160,
      "height": 40,
      "text": "What does it\nlook like?",
      "fontSize": 16,
      "fontFamily": 1,
      "textAlign": "center",
      "strokeColor": "#1e1e1e"
    },
    {
      "id": "arrow-left",
      "type": "arrow",
      "x": 280,
      "y": 200,
      "width": 130,
      "height": 60,
      "points": [[0, 0], [-130, 60]],
      "strokeColor": "#868e96",
      "strokeWidth": 2,
