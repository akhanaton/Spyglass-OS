    },
    {
      "id": "key-text",
      "type": "text",
      "x": 160,
      "y": 180,
      "width": 420,
      "height": 25,
      "text": "Read fg(x) RIGHT to LEFT: do g first, then f",
      "fontSize": 16,
      "fontFamily": 1,
      "textAlign": "center"
    }
  ],
  "appState": {
    "gridSize": null,
    "viewBackgroundColor": "#ffffff"
  },
  "files": {}
